# Prerequisites
*.d

# Object files
*.o
*.ko
*.obj
!*.obj.obj
*.elf

# Allow Wavefront OBJ model files in lesson directories
!lessons/**/models/**/*.obj
!lessons/**/assets/raw/**/*.obj

# Linker output
*.ilk
*.map
*.exp

# Precompiled Headers
*.gch
*.pch

# Libraries
*.lib
*.a
*.la
*.lo

# Shared objects (inc. Windows DLLs)
*.dll
*.so
*.so.*
*.dylib

# Executables
*.exe
*.out
*.app
*.i*86
*.x86_64
*.hex

# Debug files
*.dSYM/
*.su
*.idb
*.pdb

# Kernel Module Compile Results
*.mod*
*.cmd
.tmp_versions/
modules.order
Module.symvers
Mkfile.old
dkms.conf

# debug information files
*.dwo

# BMP files generated by running UI lessons — programs write BMP (no
# libpng dependency), but we commit PNG conversions under assets/ instead.
*.bmp

# CMake build directories
build/
build2/

# Claude Code local settings
.claude/settings.local.json

# Local editor config
.clang-format
__pycache__
*.egg-info/
.pytest_cache/
dist/
.venv/
venv/

# Audio files — user-supplied, not distributed (copyright/size)
assets/audio/*.wav
assets/audio/*.mp3
assets/audio/*.ogg
assets/audio/*.flac

# Audio lesson config — local paths to user-supplied audio files
lessons/**/audio.conf

# Asset pipeline cache (generated at runtime)
.forge-cache/

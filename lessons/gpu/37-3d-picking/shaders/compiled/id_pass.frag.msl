#include <metal_stdlib>
#include <simd/simd.h>

using namespace metal;

struct type_IdFragUniforms
{
    float4 id_color;
};

struct main0_out
{
    float4 out_var_SV_Target [[color(0)]];
};

fragment main0_out main0(constant type_IdFragUniforms& IdFragUniforms [[buffer(0)]])
{
    main0_out out = {};
    out.out_var_SV_Target = IdFragUniforms.id_color;
    return out;
}


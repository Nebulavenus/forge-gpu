#include <metal_stdlib>
#include <simd/simd.h>

using namespace metal;

struct main0_out
{
    float4 out_var_SV_Target [[color(0)]];
};

struct main0_in
{
    float2 in_var_TEXCOORD0 [[user(locn0)]];
};

fragment main0_out main0(main0_in in [[stage_in]], texture2d<float> shadow_map [[texture(0)]], sampler smp [[sampler(0)]])
{
    main0_out out = {};
    out.out_var_SV_Target = float4(shadow_map.sample(smp, in.in_var_TEXCOORD0).xxx, 1.0);
    return out;
}


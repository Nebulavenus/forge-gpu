#include <metal_stdlib>
#include <simd/simd.h>

using namespace metal;

struct type_OutlineUniforms
{
    float4 outline_color;
};

struct main0_out
{
    float4 out_var_SV_Target [[color(0)]];
};

fragment main0_out main0(constant type_OutlineUniforms& OutlineUniforms [[buffer(0)]])
{
    main0_out out = {};
    out.out_var_SV_Target = OutlineUniforms.outline_color;
    return out;
}

